# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Redis connection URL (e.g. redis://localhost:6379 or ******host:port)
REDIS_URL=redis://localhost:6379

# Duration to time out flagged users, in seconds (default: 600 = 10 minutes)
TIMEOUT_DURATION=600

# --- Cross-channel image settings ---
# How many images a user may send across multiple channels before being flagged
CROSS_CHANNEL_IMAGE_THRESHOLD=2
# How many different channels those images must span
CROSS_CHANNEL_IMAGE_CHANNEL_THRESHOLD=2
# Maximum pHash Hamming distance for two images to count as matching
CROSS_CHANNEL_IMAGE_MAX_DISTANCE=6
# Sliding window length in seconds for cross-channel image detection
CROSS_CHANNEL_IMAGE_WINDOW=60

# --- Cross-channel duplicate message settings ---
# How many different channels the same message may appear in within CROSS_CHANNEL_WINDOW seconds
CROSS_CHANNEL_THRESHOLD=3
# Sliding window length in seconds for cross-channel duplicate detection
CROSS_CHANNEL_WINDOW=60

# (Optional) ID of the channel where flagged-user alerts are sent
LOG_CHANNEL_ID=
